# Copy to .env and uncomment what you want to override. Every value shown
# is the compose default, so an untouched copy changes nothing.

# ---- Host ports & paths ----
# HTTP_PORT=80
# HTTPS_PORT=443
# UI_PORT=9000
# UI_BIND=127.0.0.1            # avoid 0.0.0.0 on public hosts
# NGINX_CONF_DIR=./nginx/conf
# NGINX_LOG_DIR=./nginx/logs
# DATA_DIR=./lightngx          # keep this volume
# TZ=UTC

# ---- Security ----
# LN_SECURE_COOKIES=true       # false only for plain-HTTP testing
# LN_SESSION_SECRET=           # fixed 32+ chars so sessions survive a restart
# LN_SESSION_TTL=12h
# LN_TRUSTED_PROXIES=          # e.g. 127.0.0.1 behind a proxy

# ---- Features ----
# LN_SITES=true
# LN_MAINTENANCE=true
# LN_MAINTENANCE_PAGE=          # path to a custom 503 HTML (built-in if unset)
# LN_STREAMS=true
# LN_DOCKER_LOGS=false
# LN_LOGROTATE=true             # rotate nginx logs on a timer

# ---- Pre-seeded admin (optional) ----
# Hash: docker run --rm -i ghcr.io/buco7854/lightngx:latest lightngx hash
# Double every "$" as "$$" so compose doesn't expand it.
# LN_ADMIN_USER=
# LN_ADMIN_PASSWORD_HASH=

# ---- Two-factor / WebAuthn (optional) ----
# LN_MFA_REQUIRED_ROLES defaults to admin; set admin,user to include users,
# or leave it empty (LN_MFA_REQUIRED_ROLES=) to disable.
# LN_MFA_REQUIRED_ROLES=admin
# LN_WEBAUTHN_RPID=              # auto-derived from the request host

# ---- OIDC (optional) ----
# LN_OIDC_ISSUER=
# LN_OIDC_CLIENT_ID=
# LN_OIDC_CLIENT_SECRET=
# LN_OIDC_REDIRECT_URL=         # https://<host>/api/auth/oidc/callback
# LN_OIDC_GROUPS_CLAIM=groups
# LN_OIDC_ALLOWED_GROUPS=       # groups allowed to log in
# LN_OIDC_ADMIN_GROUPS=         # groups granted the admin role

# ---- CrowdSec bouncer (full image only) ----
# CROWDSEC_LAPI_URL=            # e.g. http://crowdsec:8080
# CROWDSEC_LAPI_KEY=
