# Copy to .env, fill the two required secrets, then: docker compose up -d.
# Everything else has a default the compose already applies.

# ---- Required ----
# Shared key between nginx and the CrowdSec LAPI. Any random string works;
# CrowdSec registers it on first boot and the bouncer authenticates with it.
CROWDSEC_BOUNCER_KEY=
# Password for the CrowdSec Postgres database.
CROWDSEC_DB_PASSWORD=

# ---- Host paths ----
# UI_BIND=127.0.0.1             # who reaches the management UI; avoid 0.0.0.0 publicly
# NGINX_CONF_DIR=./nginx/conf   # bind mount for /etc/nginx (seeded if empty)
# NGINX_LOG_DIR=./nginx/logs    # bind mount for /var/log/nginx (shared with CrowdSec)
# DATA_DIR=./lightngx           # bind mount for /var/lib/lightngx (keep it)
# CERT_DIR=/etc/ssl/domains     # mounted read-only at the same path
# TZ=UTC

# ---- Security & sessions ----
# LN_SECURE_COOKIES=true        # false only for plain-HTTP testing
# LN_SESSION_SECRET=            # fixed 32+ chars so sessions survive a restart
# LN_SESSION_TTL=12h
# LN_TRUSTED_PROXIES=           # e.g. 127.0.0.1 behind a proxy; CIDRs allowed
# LN_MAX_EDIT_SIZE=2097152      # largest editable config file, in bytes (2 MiB)

# ---- Features ----
# LN_SITES=true
# LN_STREAMS=true
# LN_MAINTENANCE=true
# LN_MAINTENANCE_PAGE=          # path to a custom 503 HTML (built-in if unset)
# LN_LOGROTATE=true
# LN_AUTO_RELOAD=true           # reload nginx after an edit passes nginx -t
# LN_LOG_PATHS=/var/log/nginx   # dirs/files the log viewer may read (: or ,)

# ---- Pre-seeded admin (optional) ----
# Hash: docker run --rm -i ghcr.io/buco7854/lightngx:full lightngx hash
# Double every "$" as "$$" so compose does not expand it.
# LN_ADMIN_USER=
# LN_ADMIN_PASSWORD_HASH=

# ---- Two-factor / WebAuthn ----
# LN_MFA_REQUIRED_ROLES defaults to admin; set admin,user to include users,
# or leave it empty (LN_MFA_REQUIRED_ROLES=) to disable two-factor entirely.
# LN_MFA_REQUIRED_ROLES=admin
# LN_WEBAUTHN_RPID=             # auto-derived from the request host
# LN_WEBAUTHN_ORIGINS=          # extra allowed origins, comma separated

# ---- OIDC (optional) ----
# LN_OIDC_ISSUER=               # discovery base URL; enables OIDC login
# LN_OIDC_CLIENT_ID=
# LN_OIDC_CLIENT_SECRET=
# LN_OIDC_REDIRECT_URL=         # https://<host>/api/auth/oidc/callback
# LN_OIDC_SCOPES=openid,profile,email
# LN_OIDC_GROUPS_CLAIM=groups
# LN_OIDC_ALLOWED_GROUPS=       # groups allowed to log in (empty = any)
# LN_OIDC_ADMIN_GROUPS=         # groups granted the admin role
# LN_OIDC_LABEL=                # names the login button: "Sign in with <label>"
# Manual endpoints, only for providers without discovery (set the first three
# together; USERINFO is optional):
# LN_OIDC_AUTH_URL=
# LN_OIDC_TOKEN_URL=
# LN_OIDC_JWKS_URL=
# LN_OIDC_USERINFO_URL=

# ---- CrowdSec (optional overrides) ----
# CROWDSEC_LAPI_URL=http://crowdsec:8080
# CROWDSEC_COLLECTIONS=crowdsecurity/nginx crowdsecurity/http-cve crowdsecurity/appsec-virtual-patching
# CROWDSEC_DB_HOST=crowdsec-db   # DB host in crowdsec/conf/config.yaml.local
# CROWDSEC_DB_PORT=5432
# CROWDSEC_DB_NAME=crowdsec
# CROWDSEC_DB_USER=crowdsec
# CROWDSEC_CONF_DIR=./crowdsec/conf
# CROWDSEC_DATA_DIR=./crowdsec/data
# CROWDSEC_DB_DIR=./crowdsec/db

# ---- Container internals ----
# The image sets these; change them only if you also remap the mounts above.
# LN_LISTEN=:9000
# LN_SUPERVISE=true
# LN_DATA_DIR=/var/lib/lightngx
# LN_DB_PATH=                   # defaults to <DATA_DIR>/lightngx.db
# LN_NGINX_BIN=nginx
# LN_NGINX_CONF=/etc/nginx/nginx.conf
# LN_NGINX_CONF_DIR=/etc/nginx
# LN_NGINX_PID=/var/run/nginx.pid
# LN_FIX_CONFIG_PERMS=true      # on start, chown /etc/nginx to the worker user
# LN_NGINX_USER=                # worker user to chown to (auto-detected from nginx.conf)
# LN_SITES_AVAILABLE_DIR=       # defaults to <CONF_DIR>/sites-available
# LN_SITES_ENABLED_DIR=         # defaults to <CONF_DIR>/sites-enabled
# LN_STREAMS_AVAILABLE_DIR=     # defaults to <CONF_DIR>/streams-available
# LN_STREAMS_ENABLED_DIR=       # defaults to <CONF_DIR>/streams-enabled
