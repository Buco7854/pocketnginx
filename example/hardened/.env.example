# Copy to .env, fill the required secrets, then follow the walkthrough:
# https://buco7854.github.io/lightngx/hardened
# Full variable reference: https://buco7854.github.io/lightngx/configuration
# The gate's own secrets are key files under nginx/conf/gates/, not env vars.

# ---- Required ----
# Shared key between nginx and the CrowdSec LAPI (any random string; CrowdSec
# registers it on first boot and the bouncer authenticates with it).
CROWDSEC_BOUNCER_KEY=
# Password for the CrowdSec Postgres database.
CROWDSEC_DB_PASSWORD=

# ---- Recommended ----
# Keeps logins valid across restarts. Generate: openssl rand -hex 32
LN_SESSION_SECRET=

# ---- Optional (defaults shown) ----
# CERT_DIR=/etc/ssl/domains          # mounted read-only at the same path
# CROWDSEC_LAPI_URL=http://crowdsec:8080
# CROWDSEC_COLLECTIONS=crowdsecurity/nginx crowdsecurity/http-cve crowdsecurity/appsec-virtual-patching
# CROWDSEC_DB_HOST=crowdsec-db / CROWDSEC_DB_PORT=5432 / CROWDSEC_DB_NAME=crowdsec / CROWDSEC_DB_USER=crowdsec
# Pre-seed the first admin (skip setup): LN_ADMIN_USER / LN_ADMIN_PASSWORD_HASH
# Hash: docker run --rm -i ghcr.io/buco7854/lightngx:full lightngx hash
