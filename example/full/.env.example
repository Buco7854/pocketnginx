# Copy to .env, fill the three required secrets, then: docker compose up -d
# Everything else has a default; uncomment only what you want to override.

# ---- Required ----
# A fixed 32+ character secret so sessions survive a container recreation.
LN_SESSION_SECRET=
# Shared key between nginx and the CrowdSec LAPI. Any random string works;
# CrowdSec registers it on first boot and the bouncer authenticates with it.
CROWDSEC_BOUNCER_KEY=
# Password for the CrowdSec Postgres database.
CROWDSEC_DB_PASSWORD=

# ---- Host ports & paths ----
# HTTP_PORT=80
# HTTPS_PORT=443
# UI_PORT=9000
# UI_BIND=127.0.0.1              # avoid 0.0.0.0 on public hosts
# NGINX_CONF_DIR=./nginx/conf    # seeded if empty
# NGINX_LOG_DIR=/var/log/nginx
# DATA_DIR=./lightngx            # keep this volume
# CERT_DIR=/etc/ssl/domains
# TZ=UTC

# ---- Security ----
# LN_SECURE_COOKIES=true         # false only for plain-HTTP testing
# LN_TRUSTED_PROXIES=127.0.0.1

# ---- Pre-seeded admin (optional) ----
# Hash: docker run --rm -i ghcr.io/buco7854/lightngx:full lightngx hash
# Double every "$" as "$$" so compose doesn't expand it.
# LN_ADMIN_USER=
# LN_ADMIN_PASSWORD_HASH=

# ---- CrowdSec (optional overrides) ----
# CROWDSEC_LAPI_URL=http://crowdsec:8080
# CROWDSEC_COLLECTIONS=crowdsecurity/nginx crowdsecurity/http-cve crowdsecurity/appsec-virtual-patching
# CROWDSEC_DB_NAME=crowdsec
# CROWDSEC_DB_USER=crowdsec
# CROWDSEC_CONF_DIR=./crowdsec/conf
# CROWDSEC_DATA_DIR=./crowdsec/data
# CROWDSEC_DB_DIR=./crowdsec/db
